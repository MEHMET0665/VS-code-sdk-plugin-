{
  "name": "vs-code-sdk-migrator",
  "displayName": "SDK Migrator",
  "description": "Automates migration from a legacy SDK to a new SDK in JavaScript/TypeScript projects.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "publisher": "your-name",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:sdkMigrator.runMigration"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sdkMigrator.runMigration",
        "title": "SDK Migrator: Run Migration"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "echo \"No tests yet\"",
    "build-webview": "webpack --config webpack.webview.config.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/vscode": "^1.85.0",
    "ts-loader": "^9.5.0",
    "ts-morph": "^22.0.0",
    "typescript": "^5.6.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}


